# macOS
.DS_Store
Untitled
*.swp
# macOS Finder / iCloud などが作る "ファイル名 2.拡張子" 形式の重複
# (Rails migration が `Illegal name for migration file` で起動失敗する事故防止)
* 2.*

# UI 検証スクリーンショット (PR 検討過程の中間ファイル / 個人作業領域)
# PR に貼る場合は GitHub にドラッグ&ドロップで添付するため commit 不要
docs/screenshots/

# Env / secrets
.env
.env.local
.env.*.local
!.env.example
*.pem
*.key

# Logs
*.log
log/
backend/log/

# Dependencies
node_modules/
frontend/node_modules/
frontend/.nuxt/
frontend/.output/
frontend/.data/
frontend/dist/
frontend/dist
# ↑ Nuxt SSG (npm run generate) は dist/ symlink (→ .output/public/) を作るため
#   ディレクトリ ('frontend/dist/') と symlink ('frontend/dist') の両方を除外
frontend/coverage/

# Ruby / Rails
backend/tmp/
backend/storage/
backend/.bundle/
backend/vendor/bundle/
backend/coverage/
backend/.byebug_history

# Docker
db/data/
db/mysql-data/

# Editor
.vscode/
.idea/
*.iml

# Build artifacts
*.gem

# Terraform (infra/)
infra/.terraform/
infra/.terraform.lock.hcl
infra/terraform.tfstate
infra/terraform.tfstate.backup
infra/*.tfstate
infra/*.tfstate.*
infra/terraform.tfvars
infra/*.tfvars
!infra/terraform.tfvars.example
infra/crash.log
infra/crash.*.log
infra/override.tf
infra/override.tf.json
infra/*_override.tf
infra/*_override.tf.json
