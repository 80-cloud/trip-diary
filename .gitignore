# macOS
.DS_Store
Untitled
*.swp
# macOS Finder / iCloud などが作る "ファイル名 2.拡張子" 形式の重複
# (Rails migration が `Illegal name for migration file` で起動失敗する事故防止)
* 2.*

# UI 検証スクリーンショット (PR 検討過程の中間ファイル / 個人作業領域)
# PR に貼る場合は GitHub にドラッグ&ドロップで添付するため commit 不要
docs/screenshots/

# Env / secrets
.env
.env.local
.env.*.local
!.env.example
*.pem
*.key

# Logs
*.log
log/
backend/log/

# Dependencies
node_modules/
frontend/node_modules/
frontend/.nuxt/
frontend/.output/
frontend/.data/
frontend/dist/
frontend/coverage/

# Ruby / Rails
backend/tmp/
backend/storage/
backend/.bundle/
backend/vendor/bundle/
backend/coverage/
backend/.byebug_history

# Docker
db/data/
db/mysql-data/

# Editor
.vscode/
.idea/
*.iml

