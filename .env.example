# --- MySQL (Docker) ---
MYSQL_ROOT_PASSWORD=please_change_me
MYSQL_DATABASE=trip_diary_dev
MYSQL_USER=trip
MYSQL_PASSWORD=trip_password
MYSQL_PORT=3316

# --- Rails ---
RAILS_ENV=development
RAILS_PORT=3010
# `cd backend && bundle exec rails secret` で生成して貼り付け
SECRET_KEY_BASE=replace_me_with_rails_secret
# JWT 署名鍵 (`openssl rand -hex 64` で生成)
JWT_SECRET=replace_me_with_random_64_hex

# --- Nuxt ---
NUXT_PORT=3011
NUXT_PUBLIC_API_BASE=http://localhost:3010/api/v1
